pref-title = TransLit Settings
pref-menu-visibility-title = Context Menu Visibility
pref-menu-show-one-click-workflow = Show "One-click: translate, extract, export PDF"
pref-menu-show-translate-fulltext = Show "Translate full text (DeepSeek)"
pref-menu-show-translate-fulltext-default-prompt = Show "Translate full text (DeepSeek, default prompt)"
pref-menu-show-mineru-extract = Show "Extract figures/tables (MinerU)"
pref-menu-show-mineru-view = Show "View MinerU visual results"
pref-menu-show-export-translated-pdf = Show "Export translated PDF with visuals"
pref-menu-visibility-help = By default, only the one-click workflow menu is shown. Changes apply when the context menu opens next time.
pref-deepseek-api-key = DeepSeek API Key
pref-deepseek-base-url = DeepSeek Base URL
pref-deepseek-prompt = DeepSeek Prompt Template
pref-deepseek-prompt-help = Supported placeholders: title, itemKey, content. If content is omitted, full text will be appended automatically.
pref-deepseek-model-note = Model is fixed to deepseek-reasoner for this stage.
pref-mineru-title = MinerU Parsing Settings
pref-mineru-api-token = MinerU API Token
pref-mineru-base-url = MinerU Base URL
pref-mineru-model-version = MinerU Model Version
pref-mineru-model-version-help = Supported values: pipeline or vlm. Use MinerU-HTML for HTML files.
pref-mineru-pdf-render-command = PDF page renderer executable path (recommended)
pref-mineru-pdf-render-command-help = Set an absolute renderer exe path to prioritize it in visual crop adjustment rendering, without using TRANSLIT_PDF_RENDER_COMMAND.
pref-mineru-note = The plugin currently uses batch upload API: request upload URL, wait for parsing, and download ZIP result.
pref-export-title = PDF Export Settings
pref-export-headless-browser-path = Headless browser executable path (optional)
pref-export-headless-browser-path-help = Leave empty to auto-detect Edge/Chrome. You can also set an absolute browser exe path, e.g. C:\Program Files\Microsoft\Edge\Application\msedge.exe.
pref-export-font-family = PDF font family
pref-export-font-family-help = Example: 'Noto Serif CJK SC', 'Source Han Serif SC', 'SimSun', serif.
pref-export-font-size-pt = PDF body font size (pt)
pref-export-font-size-pt-help = Recommended range: 8-24.
pref-export-body-width-percent = Body width (%)
pref-export-body-width-percent-help = Recommended range: 60-100. Smaller value means wider side margins.
pref-export-paragraph-indent-em = First-line indent (em)
pref-export-paragraph-indent-em-help = Recommended range: 0-6. Value 2 means 2-em first-line indent.
pref-help = { $name } Build { $version } { $time }
